<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Tus resultados — TestYourFriends</title>
</head>
<body style="margin:0;padding:0;background-color:#f1f3f5;font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,Helvetica,Arial,sans-serif;">

  <table width="100%" cellpadding="0" cellspacing="0" border="0" style="background-color:#f1f3f5;">
    <tr>
      <td align="center" style="padding:40px 16px;">

        <!-- Outer card -->
        <table width="560" cellpadding="0" cellspacing="0" border="0" style="max-width:560px;width:100%;border-radius:16px;overflow:hidden;box-shadow:0 4px 24px rgba(0,0,0,0.10);">

          <!-- ── Header ── -->
          <tr>
            <td style="background-color:#0a0a0f;padding:28px 40px;text-align:center;">
              <p style="margin:0;color:#ffffff;font-size:22px;font-weight:800;letter-spacing:-0.4px;">TestYourFriends</p>
              <p style="margin:6px 0 0;color:rgba(255,255,255,0.45);font-size:13px;letter-spacing:0.02em;">SESIÓN {{sessionCode}}</p>
            </td>
          </tr>

          <!-- ── Body ── -->
          <tr>
            <td style="background-color:#ffffff;padding:36px 40px 28px;">

              <!-- Greeting -->
              <p style="margin:0 0 8px;font-size:16px;color:#374151;">Hola <strong style="color:#111827;">{{participantName}}</strong>,</p>
              <p style="margin:0 0 28px;font-size:15px;color:#6b7280;line-height:1.6;">Aquí están tus resultados del quiz <strong style="color:#111827;">{{quizTitle}}</strong>. ¡Comparte el link con tu grupo para ver cómo les fue a todos!</p>

              <!-- ── Character card ── -->
              <table width="100%" cellpadding="0" cellspacing="0" border="0" style="background-color:#f8f9fa;border-radius:12px;margin-bottom:32px;">
                <tr>
                  <td style="padding:24px;">
                    <table cellpadding="0" cellspacing="0" border="0" width="100%">
                      <tr>
                        <!-- Photo -->
                        <td width="88" style="vertical-align:top;padding-right:20px;">
                          <img
                            src="{{characterPhotoUrl}}"
                            width="80"
                            height="80"
                            alt="{{characterName}}"
                            style="display:block;width:80px;height:80px;border-radius:50%;object-fit:cover;border:3px solid #e5e7eb;background-color:#e5e7eb;"
                          />
                        </td>
                        <!-- Info -->
                        <td style="vertical-align:middle;">
                          <p style="margin:0 0 4px;font-size:19px;font-weight:800;color:#111827;letter-spacing:-0.3px;">{{characterName}}</p>
                          <p style="margin:0;font-size:14px;color:#6b7280;line-height:1.6;">{{characterDescription}}</p>
                        </td>
                      </tr>
                    </table>
                  </td>
                </tr>
              </table>

              <!-- ── Scores ── -->
              <p style="margin:0 0 18px;font-size:11px;font-weight:700;color:#9ca3af;text-transform:uppercase;letter-spacing:0.1em;">Tus puntuaciones</p>

              {{#each scores}}
              <!-- Score row -->
              <table width="100%" cellpadding="0" cellspacing="0" border="0" style="margin-bottom:18px;">
                <tr>
                  <td>
                    <!-- Label + value -->
                    <table width="100%" cellpadding="0" cellspacing="0" border="0" style="margin-bottom:7px;">
                      <tr>
                        <td style="font-size:14px;color:#374151;font-weight:500;">{{label}}</td>
                        <td style="text-align:right;font-size:15px;color:#111827;font-weight:700;">
                          {{score}}<span style="color:#9ca3af;font-size:13px;font-weight:400;">/10</span>
                        </td>
                      </tr>
                    </table>
                    <!-- Bar -->
                    <table width="100%" cellpadding="0" cellspacing="0" border="0" style="border-radius:6px;overflow:hidden;">
                      <tr>
                        <td width="{{barPercent}}%" height="10" bgcolor="#111827" style="background-color:#111827;border-radius:6px 0 0 6px;font-size:0;line-height:0;">&nbsp;</td>
                        <td height="10" bgcolor="#e5e7eb" style="background-color:#e5e7eb;border-radius:0 6px 6px 0;font-size:0;line-height:0;">&nbsp;</td>
                      </tr>
                    </table>
                  </td>
                </tr>
              </table>
              {{/each}}

              <!-- ── CTA ── -->
              <table width="100%" cellpadding="0" cellspacing="0" border="0" style="margin-top:32px;">
                <tr>
                  <td align="center">
                    <a
                      href="{{groupResultsUrl}}"
                      style="display:inline-block;background-color:#111827;color:#ffffff;text-decoration:none;padding:14px 36px;border-radius:10px;font-size:15px;font-weight:700;letter-spacing:-0.1px;"
                    >
                      Ver resultados del grupo &rarr;
                    </a>
                  </td>
                </tr>
              </table>

            </td>
          </tr>

          <!-- ── Footer ── -->
          <tr>
            <td style="background-color:#f9fafb;border-top:1px solid #e5e7eb;padding:20px 40px;text-align:center;">
              <p style="margin:0;font-size:12px;color:#9ca3af;">&copy; {{year}} TestYourFriends &nbsp;·&nbsp; <a href="https://testyourfriends.com" style="color:#9ca3af;text-decoration:none;">testyourfriends.com</a></p>
            </td>
          </tr>

        </table>
      </td>
    </tr>
  </table>

</body>
</html>
