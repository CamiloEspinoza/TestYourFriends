# PostgreSQL
POSTGRES_USER=postgres
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD
POSTGRES_DB=testyourfriends

# Backend
DATABASE_URL=postgresql://postgres:CHANGE_ME@localhost:5434/testyourfriends?schema=public
REDIS_HOST=localhost
REDIS_PORT=6381
REDIS_PASSWORD=CHANGE_ME_REDIS_PASSWORD
PORT=3020
NODE_ENV=production

# Auth
JWT_SECRET=CHANGE_ME_RANDOM_64_CHAR_STRING
JWT_EXPIRATION=7d

# CORS (comma-separated origins)
CORS_ORIGINS=https://testyourfriends.com

# Email (SES) - leave blank to disable (logs to console)
AWS_REGION=us-east-1
AWS_SMTP_USER=
AWS_SMTP_PASS=
SES_FROM_EMAIL=noreply@testyourfriends.com

# App
APP_BASE_URL=https://testyourfriends.com

# Frontend (build-time)
NEXT_PUBLIC_API_URL=https://testyourfriends.com/api
